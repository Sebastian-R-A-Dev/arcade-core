DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arcadecore?schema=public"
PORT=3000
NODE_ENV=development
BCRYPT_SALT_ROUNDS=12

JWT_ACCESS_SECRET="908c581000606966b2e62b448f8d557c18136e7a946ed25fef358e3750096ba63dc779d7db0b6e3e8b3962841e85424f3571152f5fca779d4979f749499d0ccd"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=1

# Browser origins allowed for credentialed CORS (comma-separated). Must include generic-login + each app origin.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Refresh cookie prefix; each app gets its own cookie: arcade_refresh_ADMIN_APP, arcade_refresh_ENGLISH-CHALLENGE, etc.
# Optional: REFRESH_COOKIE_NAME=arcade_refresh
# Prod / HTTPS: NODE_ENV=production uses Secure cookies + SameSite=None for cross-site fronts.

# Supabase Storage (/api/v1/admin/images). Usa service_role en servidor.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role (Dashboard → Settings → API → service_role). Obligatorio para Storage desde el servidor.
# No uses sb_publishable_* aquí: las subidas fallan con políticas RLS.
SUPABASE_KEY=your-service-role-secret
QUESTIONS_IMAGES_BUCKET=questions-images
AUDIOS_FOR_APPS_BUCKET=audios-for-apps

# Primera vez: aplicar migraciones y datos iniciales (ADMIN_APP + admin)
#   npm run db:setup
# o: npm run prisma:migrate && npm run db:seed
